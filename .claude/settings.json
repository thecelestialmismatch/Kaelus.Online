{
  "model": "claude-sonnet-4-6",
  "autoMemoryEnabled": true,
  "defaultModel": "sonnet",
  "extendedThinking": {
    "maxTokens": 8000
  },
  "statusLine": {
    "enabled": true,
    "format": "{model} · {tokens_used}/{context_limit} · ${cost_usd}",
    "refreshMs": 2000
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx jest *)",
      "Bash(npx supabase *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(find * -type f *)",
      "Bash(grep -r *)",
      "Bash(sed -n *)",
      "Bash(wc -l *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push origin main *)",
      "Bash(vercel --prod *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "cd /home/user/HoundShield/compliance-firewall-agent && npx tsc --noEmit --incremental 2>&1 | grep 'error TS' | head -3 || true",
        "timeout": 15000
      }
    ],
    "PreCommit": [
      {
        "command": "/home/user/HoundShield/.claude/hooks/pre-commit.sh",
        "timeout": 60000
      }
    ]
  }
}
